FILMU_PY_ENV=development
FILMU_PY_VERSION=0.1.0
FILMU_PY_HOST=0.0.0.0
FILMU_PY_PORT=8080
FILMU_PY_API_KEY=replace-with-32-char-minimum-api-key

FILMU_PY_POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/filmu
FILMU_PY_REDIS_URL=redis://localhost:6379/0

FILMU_PY_TEMPORAL_ENABLED=false
FILMU_PY_TEMPORAL_TARGET=localhost:7233
FILMU_PY_TEMPORAL_NAMESPACE=default
# Migration/worker controls for startup safety and orchestration tuning.
# Keep ARQ disabled until worker processes and job routes are configured.
FILMU_PY_RUN_MIGRATIONS_ON_STARTUP=true
FILMU_PY_ARQ_ENABLED=false
FILMU_PY_ARQ_QUEUE_NAME=filmu-py
FILMU_PY_ARQ_MAX_JOBS=32
FILMU_PY_ARQ_JOB_TIMEOUT_SECONDS=900
FILMU_PY_UNSAFE_CLEAR_QUEUES_ON_STARTUP=false
FILMU_PY_UNSAFE_REFRESH_DATABASE_ON_STARTUP=false

FILMU_PY_OTEL_ENABLED=false
FILMU_PY_OTEL_EXPORTER_OTLP_ENDPOINT=
FILMU_PY_SENTRY_DSN=

FILMU_PY_LOG_LEVEL=INFO
FILMU_PY_PROMETHEUS_ENABLED=true
FILMU_PY_PLUGINS_DIR=

# === TMDB ===
# Required for RTN title similarity matching during scrape parsing.
# The frontend has its own hardcoded TMDB read token for display purposes —
# this key is separate and needed for backend-side metadata enrichment and title matching.
TMDB_API_KEY=f6f65898351707906a8ed390d85d7a4b

# === Debrid providers (at least one required for debrid stage) ===
# Provider priority when multiple are enabled: Real-Debrid > AllDebrid > Debrid-Link
# These act as bootstrap defaults only and are overridden by values saved through
# the frontend downloaders settings page. Runtime source of truth is the persisted
# `settings.downloaders.*.api_key` configuration, not the env var directly.
REAL_DEBRID_API_KEY=
ALL_DEBRID_API_KEY=
DEBRID_LINK_API_KEY=

# Local Docker stack helpers for `docker-compose.local.yml`.
# Keep these aligned with the DSN defaults above unless you deliberately change both.
POSTGRES_DB=filmu
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Frontend container settings for local integration testing.
FRONTEND_AUTH_SECRET=replace-with-32-char-minimum-auth-secret
FRONTEND_ORIGIN=http://localhost:3000

# Playback-proof / CI helpers.
# `FILMU_FRONTEND_CONTEXT` points at the frontend source tree used by `docker-compose.local.yml`.
# Keep the local default when the sibling frontend checkout already exists; override it on CI/self-hosted runners.
FILMU_FRONTEND_CONTEXT=../../Triven_riven-fork/Triven_frontend
# Set this when the preferred-client proof should use a real host browser instead of the container browser.
FILMU_PREFERRED_CLIENT_BROWSER_EXECUTABLE=
FILMU_BACKEND_CONTAINER_NAME=filmu-python

# Local media-server containers used for native Windows playback validation.
MEDIA_SERVER_PUID=1000
MEDIA_SERVER_PGID=1000
MEDIA_SERVER_TZ=Etc/UTC
PLEX_CLAIM=
PLEX_URL=http://localhost:32401
PLEX_TOKEN=
JELLYFIN_URL=http://localhost:8096
JELLYFIN_API_KEY=
EMBY_URL=http://localhost:8097
EMBY_API_KEY=

