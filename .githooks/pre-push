#!/usr/bin/env bash

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
if [[ -z "${repo_root:-}" ]]; then
  echo "pre-push: could not resolve repository root" >&2
  exit 1
fi

ps_exe=""
if command -v pwsh >/dev/null 2>&1; then
  ps_exe="pwsh"
elif command -v powershell.exe >/dev/null 2>&1; then
  ps_exe="powershell.exe"
else
  echo "pre-push: pwsh or powershell.exe is required to run branch hygiene checks" >&2
  exit 1
fi

remote_name="${1:-origin}"
remote_url="${2:-}"
seen=""

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "${remote_ref}" != refs/heads/* ]]; then
    continue
  fi

  if [[ "${local_ref}" == refs/heads/* ]]; then
    branch="${local_ref#refs/heads/}"
  elif [[ "${local_ref}" == "HEAD" ]]; then
    branch="HEAD"
  else
    branch="${local_ref}"
  fi
  review_branch="${remote_ref#refs/heads/}"
  key="${local_sha}->${review_branch}"
  if [[ " ${seen} " == *" ${key} "* ]]; then
    continue
  fi
  seen="${seen} ${key}"

  "${ps_exe}" -NoProfile -File "${repo_root}/scripts/check_forbidden_publish_paths.ps1" -LocalRef "${local_ref}" -LocalSha "${local_sha}" -RemoteRef "${remote_ref}" -RemoteSha "${remote_sha}"

  "${ps_exe}" -NoProfile -File "${repo_root}/scripts/check_branch_hygiene.ps1" -Branch "${branch}" -ReviewBranch "${review_branch}" -Remote "${remote_name}" -NoFetch '-LocalSourceOfTruth:$true'
done

exit 0
