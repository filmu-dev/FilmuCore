#!/usr/bin/env bash

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
if [[ -z "${repo_root:-}" ]]; then
  echo "pre-push: could not resolve repository root" >&2
  exit 1
fi

ps_exe=""
if command -v pwsh >/dev/null 2>&1; then
  ps_exe="pwsh"
elif command -v powershell.exe >/dev/null 2>&1; then
  ps_exe="powershell.exe"
else
  echo "pre-push: pwsh or powershell.exe is required to run branch hygiene checks" >&2
  exit 1
fi

remote_name="${1:-origin}"
remote_url="${2:-}"
seen=""
zero_sha="0000000000000000000000000000000000000000"

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "${remote_ref}" != refs/heads/* ]]; then
    continue
  fi
  if [[ "${local_sha}" == "${zero_sha}" ]]; then
    continue
  fi

  branch=""
  commitish="${local_sha}"
  if [[ "${local_ref}" == refs/heads/* ]]; then
    branch="${local_ref#refs/heads/}"
    commitish="${branch}"
  fi

  review_branch="${remote_ref#refs/heads/}"
  source_label="${branch:-${local_sha}}"
  key="${source_label}->${review_branch}"
  if [[ " ${seen} " == *" ${key} "* ]]; then
    continue
  fi
  seen="${seen} ${key}"

  "${ps_exe}" -NoProfile -File "${repo_root}/scripts/check_forbidden_publish_paths.ps1" -LocalRef "${local_ref}" -LocalSha "${local_sha}" -RemoteRef "${remote_ref}" -RemoteSha "${remote_sha}"

  hygiene_args=(
    -NoProfile
    -File "${repo_root}/scripts/check_branch_hygiene.ps1"
    -ReviewBranch "${review_branch}"
    -Remote "${remote_name}"
    -NoFetch
    '-LocalSourceOfTruth:$true'
    -Commitish "${commitish}"
  )
  if [[ -n "${branch}" ]]; then
    hygiene_args+=(-Branch "${branch}")
  fi

  "${ps_exe}" "${hygiene_args[@]}"
done

exit 0
